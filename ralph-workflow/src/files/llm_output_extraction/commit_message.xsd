<?xml version="1.0" encoding="UTF-8"?>
<!--
  Commit Message XSD Schema
  
  Allows <code> elements within text content for escaping special characters
  like <, >, and & (e.g., comparisons, generics, logical operators).
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  
  <!-- Text with optional inline code elements -->
  <xs:complexType name="TextWithCodeType" mixed="true">
    <xs:choice minOccurs="0" maxOccurs="unbounded">
      <xs:element name="code" type="xs:string"/>
    </xs:choice>
  </xs:complexType>
  
  <xs:element name="ralph-commit">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="ralph-subject" type="TextWithCodeType"/>
        <xs:element name="ralph-body" type="TextWithCodeType" minOccurs="0"/>
        <xs:element name="ralph-body-summary" type="TextWithCodeType" minOccurs="0"/>
        <xs:element name="ralph-body-details" type="TextWithCodeType" minOccurs="0"/>
        <xs:element name="ralph-body-footer" type="TextWithCodeType" minOccurs="0"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
