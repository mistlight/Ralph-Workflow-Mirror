{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_478b4c71ea474a9ab1ead1cd","type":"tool_result","content":"     1→//! Integration tests for delta deduplication using real log data.\n     2→//!\n     3→//! This module tests the deduplication system against real-world streaming logs\n     4→//! to ensure that:\n     5→//! 1. No duplicate renders occur in production scenarios\n     6→//! 2. Snapshot glitches are properly repaired\n     7→//! 3. Consecutive duplicates are filtered\n     8→//! 4. Intentional repetition is preserved\n     9→//!\n    10→//! The tests use curated log snippets from actual `.agent/logs/` files showing\n    11→//! problematic patterns that slipped through unit testing.\n    12→\n    13→use std::fs::File;\n    14→use std::io::{BufRead, BufReader};\n    15→use std::path::Path;\n    16→\n    17→use ralph_workflow::json_parser::streaming_state::StreamingSession;\n    18→use ralph_workflow::json_parser::types::ContentType;\n    19→\n    20→// Test metrics structure\n    21→#[derive(Debug, Default, Clone)]\n    22→struct DeduplicationMetrics {\n    23→    total_deltas_received: usize,\n    24→    deltas_rendered: usize,\n    25→    snapshots_detected: usize,\n    26→    consecutive_duplicates_filtered: usize,\n    27→    final_rendered_content: String,\n    28→}\n    29→\n    30→impl DeduplicationMetrics {\n    31→    fn deduplication_effectiveness(&self) -> f64 {\n    32→        if self.total_deltas_received == 0 {\n    33→            1.0\n    34→        } else {\n    35→            1.0 - (self.deltas_rendered as f64 / self.total_deltas_received as f64)\n    36→        }\n    37→    }\n    38→\n    39→    fn has_duplicate_lines(&self) -> bool {\n    40→        let lines: Vec<&str> = self\n    41→            .final_rendered_content\n    42→            .lines()\n    43→            .filter(|l| !l.is_empty())\n    44→            .collect();\n    45→\n    46→        for i in 1..lines.len() {\n    47→            if lines[i] == lines[i - 1] {\n    48→                return true;\n    49→            }\n    50→        }\n    51→\n    52→        false\n    53→    }\n    54→}\n    55→\n    56→/// Load and parse a log file in NDJSON format\n    57→fn load_log_file(path: &Path) -> Vec<serde_json::Value> {\n    58→    let file = File::open(path).unwrap_or_else(|_| panic!(\"Failed to open log file: {:?}\", path));\n    59→    let reader = BufReader::new(file);\n    60→    let mut events = Vec::new();\n    61→\n    62→    for json_str in reader.lines().map_while(Result::ok) {\n    63→        if let Ok(value) = serde_json::from_str::<serde_json::Value>(&json_str) {\n    64→            events.push(value);\n    65→        }\n    66→    }\n    67→\n    68→    events\n    69→}\n    70→\n    71→/// Extract content_block_delta events from a log\n    72→fn extract_deltas(events: &[serde_json::Value]) -> Vec<(u64, String)> {\n    73→    events\n    74→        .iter()\n    75→        .filter_map(|event| {\n    76→            if event[\"type\"] == \"stream_event\" {\n    77→                if let Some(inner_event) = event.get(\"event\") {\n    78→                    if inner_event[\"type\"] == \"content_block_delta\" {\n    79→                        if let Some(index) = inner_event.get(\"index\").and_then(|i| i.as_u64()) {\n    80→                            if let Some(delta) = inner_event.get(\"delta\") {\n    81→                                if let Some(text) = delta.get(\"text\") {\n    82→                                    return text.as_str().map(|s| (index, s.to_string()));\n    83→                                }\n    84→                            }\n    85→                        }\n    86→                    }\n    87→                }\n    88→            }\n    89→            None\n    90→        })\n    91→        .collect()\n    92→}\n    93→\n    94→/// Simulate the deduplication process on real log data\n    95→fn simulate_deduplication(deltas: &[(u64, String)]) -> DeduplicationMetrics {\n    96→    let mut session = StreamingSession::new();\n    97→    let mut metrics = DeduplicationMetrics {\n    98→        total_deltas_received: deltas.len(),\n    99→        ..Default::default()\n   100→    };\n   101→\n   102→    for (index, delta) in deltas {\n   103→        let index_str = index.to_string();\n   104→\n   105→        // Get accumulated content length before processing\n   106→        let before_len = session\n   107→            .get_accumulated(ContentType::Text, &index_str)\n   108→            .map(|s| s.len())\n   109→            .unwrap_or(0);\n   110→\n   111→        // Process the delta (on_text_delta_key handles all deduplication internally)\n   112→        session.on_text_delta_key(&index_str, delta);\n   113→\n   114→        // Get accumulated content length after processing\n   115→        let after_len = session\n   116→            .get_accumulated(ContentType::Text, &index_str)\n   117→            .map(|s| s.len())\n   118→            .unwrap_or(0);\n   119→\n   120→        // If content length changed, delta was processed\n   121→        if after_len > before_len {\n   122→            metrics.deltas_rendered += 1;\n   123→        } else {\n   124→            // Content length didn't change - delta was filtered\n   125→            metrics.consecutive_duplicates_filtered += 1;\n   126→        }\n   127→    }\n   128→\n   129→    // Get final accumulated content\n   130→    if let Some(content) = session.get_accumulated(ContentType::Text, \"0\") {\n   131→        metrics.final_rendered_content = content.to_string();\n   132→    }\n   133→\n   134→    // Get snapshot repairs count from quality metrics\n   135→    let quality_metrics = session.get_streaming_quality_metrics();\n   136→    metrics.snapshots_detected = quality_metrics.snapshot_repairs_count;\n   137→\n   138→    metrics\n   139→}\n   140→\n   141→#[test]\n   142→fn test_integration_deduplication_infrastructure() {\n   143→    // Basic test to ensure infrastructure works\n   144→    let deltas = vec![\n   145→        (0, \"Hello\".to_string()),\n   146→        (0, \" World\".to_string()),\n   147→        (0, \"Hello\".to_string()), // Duplicate\n   148→    ];\n   149→\n   150→    let metrics = simulate_deduplication(&deltas);\n   151→\n   152→    assert_eq!(metrics.total_deltas_received, 3);\n   153→    assert!(metrics.deltas_rendered <= 3);\n   154→}\n   155→\n   156→#[test]\n   157→fn test_fixture_files_exist() {\n   158→    // Test that we can access the fixtures directory\n   159→    let fixtures_dir = Path::new(\"tests/deduplication_integration_tests/fixtures\");\n   160→\n   161→    assert!(\n   162→        fixtures_dir.exists(),\n   163→        \"Fixtures directory should exist at {:?}\",\n   164→        fixtures_dir\n   165→    );\n   166→}\n   167→\n   168→#[test]\n   169→fn test_load_real_log_file() {\n   170→    // Test loading a real log file (if available)\n   171→    let log_path = Path::new(\".agent/logs/developer_1_ccs-glm_0.log\");\n   172→\n   173→    if log_path.exists() {\n   174→        let events = load_log_file(log_path);\n   175→        assert!(!events.is_empty(), \"Log file should contain events\");\n   176→\n   177→        let deltas = extract_deltas(&events);\n   178→        assert!(!deltas.is_empty(), \"Log file should contain delta events\");\n   179→\n   180→        // Run deduplication simulation\n   181→        let metrics = simulate_deduplication(&deltas);\n   182→\n   183→        // Basic sanity checks\n   184→        assert_eq!(\n   185→            metrics.total_deltas_received,\n   186→            deltas.len(),\n   187→            \"Total deltas should match input\"\n   188→        );\n   189→\n   190→        // Print diagnostic information\n   191→        println!(\n   192→            \"Log file: {:?}\",\n   193→            log_path.file_name().unwrap_or(log_path.as_os_str())\n   194→        );\n   195→        println!(\"Total deltas received: {}\", metrics.total_deltas_received);\n   196→        println!(\"Deltas rendered: {}\", metrics.deltas_rendered);\n   197→        println!(\n   198→            \"Deduplication effectiveness: {:.1}%\",\n   199→            metrics.deduplication_effectiveness() * 100.0\n   200→        );\n   201→        println!(\"Snapshots detected: {}\", metrics.snapshots_detected);\n   202→        println!(\n   203→            \"Consecutive duplicates filtered: {}\",\n   204→            metrics.consecutive_duplicates_filtered\n   205→        );\n   206→        println!(\"Has duplicate lines: {}\", metrics.has_duplicate_lines());\n   207→    } else {\n   208→        println!(\"Skipping test - log file not found: {:?}\", log_path);\n   209→    }\n   210→}\n   211→\n   212→#[test]\n   213→fn test_no_duplicate_lines_in_all_logs() {\n   214→    // Comprehensive test: check all available log files for duplicate lines\n   215→    let logs_dir = Path::new(\".agent/logs\");\n   216→\n   217→    if !logs_dir.exists() {\n   218→        println!(\"Skipping test - logs directory not found\");\n   219→        return;\n   220→    }\n   221→\n   222→    let mut total_files_tested = 0;\n   223→    let mut files_with_duplicate_lines = Vec::new();\n   224→    let mut all_metrics = Vec::new();\n   225→\n   226→    // Test all .log files in the directory (non-recursive)\n   227→    for entry in std::fs::read_dir(logs_dir).expect(\"Failed to read logs directory\") {\n   228→        let entry = entry.expect(\"Failed to read directory entry\");\n   229→        let path = entry.path();\n   230→\n   231→        // Skip if not a file or doesn't have .log extension\n   232→        if path.extension().and_then(|s| s.to_str()) != Some(\"log\") {\n   233→            continue;\n   234→        }\n   235→\n   236→        let events = load_log_file(&path);\n   237→        if events.is_empty() {\n   238→            continue;\n   239→        }\n   240→\n   241→        let deltas = extract_deltas(&events);\n   242→        if deltas.is_empty() {\n   243→            continue;\n   244→        }\n   245→\n   246→        let metrics = simulate_deduplication(&deltas);\n   247→\n   248→        println!(\"\\n--- Testing: {:?} ---\", path.file_name());\n   249→        println!(\"Total deltas: {}\", metrics.total_deltas_received);\n   250→        println!(\"Deltas rendered: {}\", metrics.deltas_rendered);\n   251→        println!(\n   252→            \"Deduplication: {:.1}%\",\n   253→            metrics.deduplication_effectiveness() * 100.0\n   254→        );\n   255→        println!(\"Snapshots detected: {}\", metrics.snapshots_detected);\n   256→        println!(\n   257→            \"Consecutive duplicates filtered: {}\",\n   258→            metrics.consecutive_duplicates_filtered\n   259→        );\n   260→        println!(\"Has duplicate lines: {}\", metrics.has_duplicate_lines());\n   261→        println!(\n   262→            \"Final content length: {}\",\n   263→            metrics.final_rendered_content.len()\n   264→        );\n   265→\n   266→        total_files_tested += 1;\n   267→        all_metrics.push((path.clone(), metrics.clone()));\n   268→\n   269→        if metrics.has_duplicate_lines() {\n   270→            files_with_duplicate_lines.push(path.clone());\n   271→        }\n   272→    }\n   273→\n   274→    println!(\"\\n=== Summary ===\");\n   275→    println!(\"Total files tested: {}\", total_files_tested);\n   276→    println!(\n   277→        \"Files with duplicate lines: {}\",\n   278→        files_with_duplicate_lines.len()\n   279→    );\n   280→\n   281→    if !files_with_duplicate_lines.is_empty() {\n   282→        println!(\"\\nFiles with duplicate lines:\");\n   283→        for path in &files_with_duplicate_lines {\n   284→            println!(\"  - {:?}\", path);\n   285→        }\n   286→\n   287→        // Show first duplicate line for debugging\n   288→        for (path, metrics) in &all_metrics {\n   289→            if metrics.has_duplicate_lines() {\n   290→                println!(\"\\nDuplicate lines in {:?}:\", path.file_name());\n   291→                let lines: Vec<&str> = metrics.final_rendered_content.lines().collect();\n   292→                for i in 1..lines.len() {\n   293→                    if lines[i] == lines[i - 1] && !lines[i].is_empty() {\n   294→                        println!(\"  Line {}: \\\"{}\\\"\", i, lines[i]);\n   295→                        break; // Just show first duplicate\n   296→                    }\n   297→                }\n   298→            }\n   299→        }\n   300→    }\n   301→\n   302→    // This assertion will fail if duplicate lines are detected\n   303→    assert!(\n   304→        files_with_duplicate_lines.is_empty(),\n   305→        \"Found duplicate lines in {} log files. Deduplication is not working correctly.\",\n   306→        files_with_duplicate_lines.len()\n   307→    );\n   308→}\n   309→\n   310→#[test]\n   311→fn test_token_by_token_streaming() {\n   312→    // Test realistic token-by-token streaming pattern\n   313→    let deltas = vec![\n   314→        (0, \"Looking\".to_string()),\n   315→        (0, \" at\".to_string()),\n   316→        (0, \" the\".to_string()),\n   317→        (0, \" code\".to_string()),\n   318→        (0, \",\".to_string()),\n   319→        (0, \" I\".to_string()),\n   320→        (0, \" can\".to_string()),\n   321→        (0, \" see\".to_string()),\n   322→        (0, \" the\".to_string()),\n   323→        (0, \" issue\".to_string()),\n   324→        (0, \".\".to_string()),\n   325→    ];\n   326→\n   327→    let metrics = simulate_deduplication(&deltas);\n   328→\n   329→    // All tokens should be rendered (no deduplication needed)\n   330→    assert_eq!(metrics.deltas_rendered, deltas.len());\n   331→    assert_eq!(metrics.snapshots_detected, 0);\n   332→    assert!(!metrics.has_duplicate_lines());\n   333→}\n   334→\n   335→#[test]\n   336→fn test_snapshot_glitch_detection() {\n   337→    // Test snapshot glitch: agent sends accumulated content as delta\n   338→    let accumulated = \"The quick brown fox jumps over the lazy dog.\";\n   339→    let glitch_delta = accumulated.to_string();\n   340→\n   341→    let deltas = vec![\n   342→        (0, \"The\".to_string()),\n   343→        (0, \" quick\".to_string()),\n   344→        (0, \" brown\".to_string()),\n   345→        (0, \" fox\".to_string()),\n   346→        (0, \" jumps\".to_string()),\n   347→        (0, \" over\".to_string()),\n   348→        (0, \" the\".to_string()),\n   349→        (0, \" lazy\".to_string()),\n   350→        (0, \" dog\".to_string()),\n   351→        (0, \".\".to_string()),\n   352→        (0, glitch_delta.clone()), // Snapshot glitch - resend entire content\n   353→        (0, \" New\".to_string()),\n   354→        (0, \" content\".to_string()),\n   355→        (0, \".\".to_string()),\n   356→    ];\n   357→\n   358→    let metrics = simulate_deduplication(&deltas);\n   359→\n   360→    // Snapshot should be detected\n   361→    assert!(metrics.snapshots_detected > 0);\n   362→\n   363→    // Final content should not contain duplicate lines\n   364→    assert!(!metrics.has_duplicate_lines());\n   365→\n   366→    // The glitch should reduce render count (snapshot is detected)\n   367→    assert!(\n   368→        metrics.deltas_rendered < metrics.total_deltas_received,\n   369→        \"Deduplication should reduce the number of renders\"\n   370→    );\n   371→\n   372→    // Final content should end with the new content\n   373→    assert!(\n   374→        metrics.final_rendered_content.ends_with(\" New content.\"),\n   375→        \"Final content should include new content after snapshot, got: {}\",\n   376→        metrics.final_rendered_content\n   377→    );\n   378→}\n   379→\n   380→#[test]\n   381→fn test_consecutive_duplicate_detection() {\n   382→    // Test consecutive duplicate detection (\"3 strikes\" heuristic)\n   383→    let repeated_delta = \"This is a repeated message\".to_string();\n   384→\n   385→    let deltas = vec![\n   386→        (0, \"First\".to_string()),\n   387→        (0, repeated_delta.clone()),\n   388→        (0, repeated_delta.clone()), // 2nd time\n   389→        (0, repeated_delta.clone()), // 3rd time - should be filtered\n   390→        (0, repeated_delta.clone()), // 4th time - should be filtered\n   391→        (0, \"Final\".to_string()),\n   392→    ];\n   393→\n   394→    let metrics = simulate_deduplication(&deltas);\n   395→\n   396→    // Some consecutive duplicates should be filtered\n   397→    assert!(\n   398→        metrics.consecutive_duplicates_filtered >= 1,\n   399→        \"Should filter at least one consecutive duplicate, filtered: {}\",\n   400→        metrics.consecutive_duplicates_filtered\n   401→    );\n   402→\n   403→    // Final content should not contain excessive repeats\n   404→    let repeat_count = metrics\n   405→        .final_rendered_content\n   406→        .matches(&repeated_delta)\n   407→        .count();\n   408→\n   409→    assert!(\n   410→        repeat_count <= 2,\n   411→        \"Should not have more than 2 instances of repeated delta, found {}\",\n   412→        repeat_count\n   413→    );\n   414→}\n   415→\n   416→#[test]\n   417→fn test_intentional_repetition_preserved() {\n   418→    // Test that intentional repetition is NOT deduplicated\n   419→    let deltas = vec![\n   420→        (0, \"echo\".to_string()),\n   421→        (0, \" \".to_string()),\n   422→        (0, \"echo\".to_string()),\n   423→        (0, \" \".to_string()),\n   424→        (0, \"echo\".to_string()),\n   425→        (0, \"\\n\".to_string()),\n   426→    ];\n   427→\n   428→    let metrics = simulate_deduplication(&deltas);\n   429→\n   430→    // Short tokens like \"echo\" and \" \" should be preserved\n   431→    // because they don't meet the minimum overlap threshold\n   432→    let final_content = &metrics.final_rendered_content;\n   433→\n   434→    // The content should contain the repeated \"echo\" pattern\n   435→    assert!(\n   436→        final_content.contains(\"echo echo echo\"),\n   437→        \"Final content should preserve intentional repetition: {}\",\n   438→        final_content\n   439→    );\n   440→}\n   441→\n   442→#[test]\n   443→fn test_weak_overlap_not_deduplicated() {\n   444→    // Test that weak overlap is NOT deduplicated\n   445→    let deltas = vec![\n   446→        (0, \"Starting the process\".to_string()),\n   447→        (0, \" the process now\".to_string()), // Small overlap, but not enough\n   448→        (0, \" and continuing\".to_string()),\n   449→    ];\n   450→\n   451→    let metrics = simulate_deduplication(&deltas);\n   452→\n   453→    // Weak overlap should not trigger snapshot detection\n   454→    assert_eq!(\n   455→        metrics.snapshots_detected, 0,\n   456→        \"Weak overlap should not trigger snapshot detection\"\n   457→    );\n   458→}\n   459→\n   460→#[test]\n   461→fn test_snapshot_with_strong_overlap() {\n   462→    // Test snapshot with strong overlap (>30 chars AND >50% ratio)\n   463→    let base_content =\n   464→        \"The quick brown fox jumps over the lazy dog and then runs around the block.\";\n   465→\n   466→    let deltas = vec![\n   467→        (0, \"The\".to_string()),\n   468→        (0, \" quick\".to_string()),\n   469→        (0, \" brown\".to_string()),\n   470→        (0, \" fox\".to_string()),\n   471→        (0, \" jumps\".to_string()),\n   472→        (0, \" over\".to_string()),\n   473→        (0, \" the\".to_string()),\n   474→        (0, \" lazy\".to_string()),\n   475→        (0, \" dog\".to_string()),\n   476→        (0, \" and\".to_string()),\n   477→        (0, \" then\".to_string()),\n   478→        (0, \" runs\".to_string()),\n   479→        (0, \" around\".to_string()),\n   480→        (0, \" the\".to_string()),\n   481→        (0, \" block\".to_string()),\n   482→        (0, \".\".to_string()),\n   483→        (0, base_content.to_string()), // Snapshot: full resend\n   484→        (0, \" Extra\".to_string()),\n   485→        (0, \" content\".to_string()),\n   486→        (0, \".\".to_string()),\n   487→    ];\n   488→\n   489→    let metrics = simulate_deduplication(&deltas);\n   490→\n   491→    // Snapshot should be detected (strong overlap)\n   492→    assert!(\n   493→        metrics.snapshots_detected > 0,\n   494→        \"Strong overlap should trigger snapshot detection\"\n   495→    );\n   496→\n   497→    // No duplicate lines in final content\n   498→    assert!(!metrics.has_duplicate_lines());\n   499→}\n   500→\n   501→#[test]\n   502→fn test_short_chunks_not_deduplicated() {\n   503→    // Test that short chunks (< 20 chars) are not deduplicated unless exact match\n   504→    let deltas = vec![\n   505→        (0, \"Hi\".to_string()),\n   506→        (0, \" there\".to_string()),\n   507→        (0, \".\".to_string()),\n   508→        (0, \"Hi\".to_string()),     // Short repeat\n   509→        (0, \" there\".to_string()), // Short repeat\n   510→        (0, \"!\".to_string()),\n   511→    ];\n   512→\n   513→    let metrics = simulate_deduplication(&deltas);\n   514→\n   515→    // Short chunks should generally be preserved (not deduplicated)\n   516→    // Only exact consecutive repeats would be filtered\n   517→    assert_eq!(\n   518→        metrics.snapshots_detected, 0,\n   519→        \"Short chunks should not trigger snapshot detection\"\n   520→    );\n   521→}\n   522→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1759a263-252a-4bc4-85f3-c7b1283cbe37","uuid":"0e1cd08f-b6f5-4c84-a7c9-bdbec34cbc1a","tool_use_result":{"type":"text","file":{"filePath":"/Users/mistlight/Projects/RalphWithReviewer/wt-streaming-fix/ralph-workflow/tests/deduplication_integration_tests.rs","content":"//! Integration tests for delta deduplication using real log data.\n//!\n//! This module tests the deduplication system against real-world streaming logs\n//! to ensure that:\n//! 1. No duplicate renders occur in production scenarios\n//! 2. Snapshot glitches are properly repaired\n//! 3. Consecutive duplicates are filtered\n//! 4. Intentional repetition is preserved\n//!\n//! The tests use curated log snippets from actual `.agent/logs/` files showing\n//! problematic patterns that slipped through unit testing.\n\nuse std::fs::File;\nuse std::io::{BufRead, BufReader};\nuse std::path::Path;\n\nuse ralph_workflow::json_parser::streaming_state::StreamingSession;\nuse ralph_workflow::json_parser::types::ContentType;\n\n// Test metrics structure\n#[derive(Debug, Default, Clone)]\nstruct DeduplicationMetrics {\n    total_deltas_received: usize,\n    deltas_rendered: usize,\n    snapshots_detected: usize,\n    consecutive_duplicates_filtered: usize,\n    final_rendered_content: String,\n}\n\nimpl DeduplicationMetrics {\n    fn deduplication_effectiveness(&self) -> f64 {\n        if self.total_deltas_received == 0 {\n            1.0\n        } else {\n            1.0 - (self.deltas_rendered as f64 / self.total_deltas_received as f64)\n        }\n    }\n\n    fn has_duplicate_lines(&self) -> bool {\n        let lines: Vec<&str> = self\n            .final_rendered_content\n            .lines()\n            .filter(|l| !l.is_empty())\n            .collect();\n\n        for i in 1..lines.len() {\n            if lines[i] == lines[i - 1] {\n                return true;\n            }\n        }\n\n        false\n    }\n}\n\n/// Load and parse a log file in NDJSON format\nfn load_log_file(path: &Path) -> Vec<serde_json::Value> {\n    let file = File::open(path).unwrap_or_else(|_| panic!(\"Failed to open log file: {:?}\", path));\n    let reader = BufReader::new(file);\n    let mut events = Vec::new();\n\n    for json_str in reader.lines().map_while(Result::ok) {\n        if let Ok(value) = serde_json::from_str::<serde_json::Value>(&json_str) {\n            events.push(value);\n        }\n    }\n\n    events\n}\n\n/// Extract content_block_delta events from a log\nfn extract_deltas(events: &[serde_json::Value]) -> Vec<(u64, String)> {\n    events\n        .iter()\n        .filter_map(|event| {\n            if event[\"type\"] == \"stream_event\" {\n                if let Some(inner_event) = event.get(\"event\") {\n                    if inner_event[\"type\"] == \"content_block_delta\" {\n                        if let Some(index) = inner_event.get(\"index\").and_then(|i| i.as_u64()) {\n                            if let Some(delta) = inner_event.get(\"delta\") {\n                                if let Some(text) = delta.get(\"text\") {\n                                    return text.as_str().map(|s| (index, s.to_string()));\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n            None\n        })\n        .collect()\n}\n\n/// Simulate the deduplication process on real log data\nfn simulate_deduplication(deltas: &[(u64, String)]) -> DeduplicationMetrics {\n    let mut session = StreamingSession::new();\n    let mut metrics = DeduplicationMetrics {\n        total_deltas_received: deltas.len(),\n        ..Default::default()\n    };\n\n    for (index, delta) in deltas {\n        let index_str = index.to_string();\n\n        // Get accumulated content length before processing\n        let before_len = session\n            .get_accumulated(ContentType::Text, &index_str)\n            .map(|s| s.len())\n            .unwrap_or(0);\n\n        // Process the delta (on_text_delta_key handles all deduplication internally)\n        session.on_text_delta_key(&index_str, delta);\n\n        // Get accumulated content length after processing\n        let after_len = session\n            .get_accumulated(ContentType::Text, &index_str)\n            .map(|s| s.len())\n            .unwrap_or(0);\n\n        // If content length changed, delta was processed\n        if after_len > before_len {\n            metrics.deltas_rendered += 1;\n        } else {\n            // Content length didn't change - delta was filtered\n            metrics.consecutive_duplicates_filtered += 1;\n        }\n    }\n\n    // Get final accumulated content\n    if let Some(content) = session.get_accumulated(ContentType::Text, \"0\") {\n        metrics.final_rendered_content = content.to_string();\n    }\n\n    // Get snapshot repairs count from quality metrics\n    let quality_metrics = session.get_streaming_quality_metrics();\n    metrics.snapshots_detected = quality_metrics.snapshot_repairs_count;\n\n    metrics\n}\n\n#[test]\nfn test_integration_deduplication_infrastructure() {\n    // Basic test to ensure infrastructure works\n    let deltas = vec![\n        (0, \"Hello\".to_string()),\n        (0, \" World\".to_string()),\n        (0, \"Hello\".to_string()), // Duplicate\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    assert_eq!(metrics.total_deltas_received, 3);\n    assert!(metrics.deltas_rendered <= 3);\n}\n\n#[test]\nfn test_fixture_files_exist() {\n    // Test that we can access the fixtures directory\n    let fixtures_dir = Path::new(\"tests/deduplication_integration_tests/fixtures\");\n\n    assert!(\n        fixtures_dir.exists(),\n        \"Fixtures directory should exist at {:?}\",\n        fixtures_dir\n    );\n}\n\n#[test]\nfn test_load_real_log_file() {\n    // Test loading a real log file (if available)\n    let log_path = Path::new(\".agent/logs/developer_1_ccs-glm_0.log\");\n\n    if log_path.exists() {\n        let events = load_log_file(log_path);\n        assert!(!events.is_empty(), \"Log file should contain events\");\n\n        let deltas = extract_deltas(&events);\n        assert!(!deltas.is_empty(), \"Log file should contain delta events\");\n\n        // Run deduplication simulation\n        let metrics = simulate_deduplication(&deltas);\n\n        // Basic sanity checks\n        assert_eq!(\n            metrics.total_deltas_received,\n            deltas.len(),\n            \"Total deltas should match input\"\n        );\n\n        // Print diagnostic information\n        println!(\n            \"Log file: {:?}\",\n            log_path.file_name().unwrap_or(log_path.as_os_str())\n        );\n        println!(\"Total deltas received: {}\", metrics.total_deltas_received);\n        println!(\"Deltas rendered: {}\", metrics.deltas_rendered);\n        println!(\n            \"Deduplication effectiveness: {:.1}%\",\n            metrics.deduplication_effectiveness() * 100.0\n        );\n        println!(\"Snapshots detected: {}\", metrics.snapshots_detected);\n        println!(\n            \"Consecutive duplicates filtered: {}\",\n            metrics.consecutive_duplicates_filtered\n        );\n        println!(\"Has duplicate lines: {}\", metrics.has_duplicate_lines());\n    } else {\n        println!(\"Skipping test - log file not found: {:?}\", log_path);\n    }\n}\n\n#[test]\nfn test_no_duplicate_lines_in_all_logs() {\n    // Comprehensive test: check all available log files for duplicate lines\n    let logs_dir = Path::new(\".agent/logs\");\n\n    if !logs_dir.exists() {\n        println!(\"Skipping test - logs directory not found\");\n        return;\n    }\n\n    let mut total_files_tested = 0;\n    let mut files_with_duplicate_lines = Vec::new();\n    let mut all_metrics = Vec::new();\n\n    // Test all .log files in the directory (non-recursive)\n    for entry in std::fs::read_dir(logs_dir).expect(\"Failed to read logs directory\") {\n        let entry = entry.expect(\"Failed to read directory entry\");\n        let path = entry.path();\n\n        // Skip if not a file or doesn't have .log extension\n        if path.extension().and_then(|s| s.to_str()) != Some(\"log\") {\n            continue;\n        }\n\n        let events = load_log_file(&path);\n        if events.is_empty() {\n            continue;\n        }\n\n        let deltas = extract_deltas(&events);\n        if deltas.is_empty() {\n            continue;\n        }\n\n        let metrics = simulate_deduplication(&deltas);\n\n        println!(\"\\n--- Testing: {:?} ---\", path.file_name());\n        println!(\"Total deltas: {}\", metrics.total_deltas_received);\n        println!(\"Deltas rendered: {}\", metrics.deltas_rendered);\n        println!(\n            \"Deduplication: {:.1}%\",\n            metrics.deduplication_effectiveness() * 100.0\n        );\n        println!(\"Snapshots detected: {}\", metrics.snapshots_detected);\n        println!(\n            \"Consecutive duplicates filtered: {}\",\n            metrics.consecutive_duplicates_filtered\n        );\n        println!(\"Has duplicate lines: {}\", metrics.has_duplicate_lines());\n        println!(\n            \"Final content length: {}\",\n            metrics.final_rendered_content.len()\n        );\n\n        total_files_tested += 1;\n        all_metrics.push((path.clone(), metrics.clone()));\n\n        if metrics.has_duplicate_lines() {\n            files_with_duplicate_lines.push(path.clone());\n        }\n    }\n\n    println!(\"\\n=== Summary ===\");\n    println!(\"Total files tested: {}\", total_files_tested);\n    println!(\n        \"Files with duplicate lines: {}\",\n        files_with_duplicate_lines.len()\n    );\n\n    if !files_with_duplicate_lines.is_empty() {\n        println!(\"\\nFiles with duplicate lines:\");\n        for path in &files_with_duplicate_lines {\n            println!(\"  - {:?}\", path);\n        }\n\n        // Show first duplicate line for debugging\n        for (path, metrics) in &all_metrics {\n            if metrics.has_duplicate_lines() {\n                println!(\"\\nDuplicate lines in {:?}:\", path.file_name());\n                let lines: Vec<&str> = metrics.final_rendered_content.lines().collect();\n                for i in 1..lines.len() {\n                    if lines[i] == lines[i - 1] && !lines[i].is_empty() {\n                        println!(\"  Line {}: \\\"{}\\\"\", i, lines[i]);\n                        break; // Just show first duplicate\n                    }\n                }\n            }\n        }\n    }\n\n    // This assertion will fail if duplicate lines are detected\n    assert!(\n        files_with_duplicate_lines.is_empty(),\n        \"Found duplicate lines in {} log files. Deduplication is not working correctly.\",\n        files_with_duplicate_lines.len()\n    );\n}\n\n#[test]\nfn test_token_by_token_streaming() {\n    // Test realistic token-by-token streaming pattern\n    let deltas = vec![\n        (0, \"Looking\".to_string()),\n        (0, \" at\".to_string()),\n        (0, \" the\".to_string()),\n        (0, \" code\".to_string()),\n        (0, \",\".to_string()),\n        (0, \" I\".to_string()),\n        (0, \" can\".to_string()),\n        (0, \" see\".to_string()),\n        (0, \" the\".to_string()),\n        (0, \" issue\".to_string()),\n        (0, \".\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // All tokens should be rendered (no deduplication needed)\n    assert_eq!(metrics.deltas_rendered, deltas.len());\n    assert_eq!(metrics.snapshots_detected, 0);\n    assert!(!metrics.has_duplicate_lines());\n}\n\n#[test]\nfn test_snapshot_glitch_detection() {\n    // Test snapshot glitch: agent sends accumulated content as delta\n    let accumulated = \"The quick brown fox jumps over the lazy dog.\";\n    let glitch_delta = accumulated.to_string();\n\n    let deltas = vec![\n        (0, \"The\".to_string()),\n        (0, \" quick\".to_string()),\n        (0, \" brown\".to_string()),\n        (0, \" fox\".to_string()),\n        (0, \" jumps\".to_string()),\n        (0, \" over\".to_string()),\n        (0, \" the\".to_string()),\n        (0, \" lazy\".to_string()),\n        (0, \" dog\".to_string()),\n        (0, \".\".to_string()),\n        (0, glitch_delta.clone()), // Snapshot glitch - resend entire content\n        (0, \" New\".to_string()),\n        (0, \" content\".to_string()),\n        (0, \".\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Snapshot should be detected\n    assert!(metrics.snapshots_detected > 0);\n\n    // Final content should not contain duplicate lines\n    assert!(!metrics.has_duplicate_lines());\n\n    // The glitch should reduce render count (snapshot is detected)\n    assert!(\n        metrics.deltas_rendered < metrics.total_deltas_received,\n        \"Deduplication should reduce the number of renders\"\n    );\n\n    // Final content should end with the new content\n    assert!(\n        metrics.final_rendered_content.ends_with(\" New content.\"),\n        \"Final content should include new content after snapshot, got: {}\",\n        metrics.final_rendered_content\n    );\n}\n\n#[test]\nfn test_consecutive_duplicate_detection() {\n    // Test consecutive duplicate detection (\"3 strikes\" heuristic)\n    let repeated_delta = \"This is a repeated message\".to_string();\n\n    let deltas = vec![\n        (0, \"First\".to_string()),\n        (0, repeated_delta.clone()),\n        (0, repeated_delta.clone()), // 2nd time\n        (0, repeated_delta.clone()), // 3rd time - should be filtered\n        (0, repeated_delta.clone()), // 4th time - should be filtered\n        (0, \"Final\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Some consecutive duplicates should be filtered\n    assert!(\n        metrics.consecutive_duplicates_filtered >= 1,\n        \"Should filter at least one consecutive duplicate, filtered: {}\",\n        metrics.consecutive_duplicates_filtered\n    );\n\n    // Final content should not contain excessive repeats\n    let repeat_count = metrics\n        .final_rendered_content\n        .matches(&repeated_delta)\n        .count();\n\n    assert!(\n        repeat_count <= 2,\n        \"Should not have more than 2 instances of repeated delta, found {}\",\n        repeat_count\n    );\n}\n\n#[test]\nfn test_intentional_repetition_preserved() {\n    // Test that intentional repetition is NOT deduplicated\n    let deltas = vec![\n        (0, \"echo\".to_string()),\n        (0, \" \".to_string()),\n        (0, \"echo\".to_string()),\n        (0, \" \".to_string()),\n        (0, \"echo\".to_string()),\n        (0, \"\\n\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Short tokens like \"echo\" and \" \" should be preserved\n    // because they don't meet the minimum overlap threshold\n    let final_content = &metrics.final_rendered_content;\n\n    // The content should contain the repeated \"echo\" pattern\n    assert!(\n        final_content.contains(\"echo echo echo\"),\n        \"Final content should preserve intentional repetition: {}\",\n        final_content\n    );\n}\n\n#[test]\nfn test_weak_overlap_not_deduplicated() {\n    // Test that weak overlap is NOT deduplicated\n    let deltas = vec![\n        (0, \"Starting the process\".to_string()),\n        (0, \" the process now\".to_string()), // Small overlap, but not enough\n        (0, \" and continuing\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Weak overlap should not trigger snapshot detection\n    assert_eq!(\n        metrics.snapshots_detected, 0,\n        \"Weak overlap should not trigger snapshot detection\"\n    );\n}\n\n#[test]\nfn test_snapshot_with_strong_overlap() {\n    // Test snapshot with strong overlap (>30 chars AND >50% ratio)\n    let base_content =\n        \"The quick brown fox jumps over the lazy dog and then runs around the block.\";\n\n    let deltas = vec![\n        (0, \"The\".to_string()),\n        (0, \" quick\".to_string()),\n        (0, \" brown\".to_string()),\n        (0, \" fox\".to_string()),\n        (0, \" jumps\".to_string()),\n        (0, \" over\".to_string()),\n        (0, \" the\".to_string()),\n        (0, \" lazy\".to_string()),\n        (0, \" dog\".to_string()),\n        (0, \" and\".to_string()),\n        (0, \" then\".to_string()),\n        (0, \" runs\".to_string()),\n        (0, \" around\".to_string()),\n        (0, \" the\".to_string()),\n        (0, \" block\".to_string()),\n        (0, \".\".to_string()),\n        (0, base_content.to_string()), // Snapshot: full resend\n        (0, \" Extra\".to_string()),\n        (0, \" content\".to_string()),\n        (0, \".\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Snapshot should be detected (strong overlap)\n    assert!(\n        metrics.snapshots_detected > 0,\n        \"Strong overlap should trigger snapshot detection\"\n    );\n\n    // No duplicate lines in final content\n    assert!(!metrics.has_duplicate_lines());\n}\n\n#[test]\nfn test_short_chunks_not_deduplicated() {\n    // Test that short chunks (< 20 chars) are not deduplicated unless exact match\n    let deltas = vec![\n        (0, \"Hi\".to_string()),\n        (0, \" there\".to_string()),\n        (0, \".\".to_string()),\n        (0, \"Hi\".to_string()),     // Short repeat\n        (0, \" there\".to_string()), // Short repeat\n        (0, \"!\".to_string()),\n    ];\n\n    let metrics = simulate_deduplication(&deltas);\n\n    // Short chunks should generally be preserved (not deduplicated)\n    // Only exact consecutive repeats would be filtered\n    assert_eq!(\n        metrics.snapshots_detected, 0,\n        \"Short chunks should not trigger snapshot detection\"\n    );\n}\n","numLines":522,"startLine":1,"totalLines":522}}}
