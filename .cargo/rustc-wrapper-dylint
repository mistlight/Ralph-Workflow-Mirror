#!/usr/bin/env sh
set -eu

# Cargo `build.rustc-wrapper` wrapper.
#
# Dylint uses `RUSTC_WORKSPACE_WRAPPER` to run a nightly rustc driver on
# workspace crates, but Cargo may still compile dependencies with the default
# `rustc` in PATH. That mixture can produce "incompatible version of rustc"
# errors when workspace crates depend on those artifacts.
#
# This wrapper only activates during Dylint runs (detected via `DYLINT_LIBS` and
# `RUSTUP_TOOLCHAIN`) and forces non-Dylint invocations to use the same Rust
# toolchain.

if [ $# -lt 1 ]; then
  echo "error: rustc wrapper invoked with no args" >&2
  exit 1
fi

real="$1"
shift

dylint_libs="${DYLINT_LIBS:-}"
toolchain="${RUSTUP_TOOLCHAIN:-}"

if [ -z "$dylint_libs" ] || [ -z "$toolchain" ]; then
  exec "$real" "$@"
fi

# Dylint driver builds set CARGO=check; silence cargo progress output so
# `make dylint` can be used in "no output" verification pipelines.
#
# We set CARGO_TERM_QUIET for the `rustup run ... rustc` invocations below.
export CARGO_TERM_QUIET=true

case "$real" in
  *"/dylint-driver"|*"\\dylint-driver.exe")
    # The Dylint driver is already toolchain-specific; just run it.
    exec "$real" "$@"
    ;;
esac

if ! command -v rustup >/dev/null 2>&1; then
  echo "error: Dylint build detected but rustup is not installed" >&2
  echo "hint: install rustup and the toolchain '$toolchain'" >&2
  exit 1
fi

exec rustup run "$toolchain" rustc "$@"
